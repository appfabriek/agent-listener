# Agent Listener Configuration

# API base URL (default: https://agenttalktome.com)
API_URL=https://agenttalktome.com

# Listener credentials (auto-saved after first registration, or set manually)
REGISTRATION_TOKEN=
LISTENER_IDENTIFIER=

# Listener type and name
LISTENER_TYPE=agent
LISTENER_NAME=My Agent

# How to forward messages to the AI agent
# Options: gateway (default), openclaw-cli, webhook
FORWARD_MODE=gateway

# OpenClaw Gateway WebSocket URL (used when FORWARD_MODE=gateway)
# Auth token is auto-read from ~/.openclaw/openclaw.json
GATEWAY_URL=ws://127.0.0.1:18789
# GATEWAY_AUTH_TOKEN=  # Override auto-detected token if needed

# OpenClaw agent name (used when FORWARD_MODE=openclaw-cli or gateway)
OPENCLAW_AGENT=main

# Webhook URL (used when FORWARD_MODE=webhook)
WEBHOOK_URL=http://localhost:18888/hooks/wake
WEBHOOK_TOKEN=

# Debug mode
DEBUG=false
