# Agent Listener Configuration

# API base URL (required)
API_URL=https://bvgeert.lvh.me

# Listener registration token (set after first registration, or leave empty to auto-register)
REGISTRATION_TOKEN=

# Listener type and name
LISTENER_TYPE=agent
LISTENER_NAME=Lena

# How to forward messages to the AI agent
# Options: openclaw-cli, webhook
FORWARD_MODE=webhook

# Webhook URL (used when FORWARD_MODE=webhook)
WEBHOOK_URL=http://localhost:18888/hooks/wake
WEBHOOK_TOKEN=

# Debug mode
DEBUG=false
