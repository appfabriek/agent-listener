# OpenVoice Agent Poller Configuration

# Agent token (required) - get this from pairing
AGENT_TOKEN=oc_agent_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API URL (optional, defaults to production)
API_URL=https://api.agenttalktome.com

# Poll timeout in seconds (optional, default 30, max 30)
POLL_TIMEOUT=30

# OpenClaw integration method (optional)
# Set to 'false' to use webhook instead of CLI
USE_OPENCLAW_CLI=true

# OpenClaw webhook URL (only used if USE_OPENCLAW_CLI=false)
OPENCLAW_WEBHOOK_URL=http://localhost:18888/hooks/wake
OPENCLAW_WEBHOOK_TOKEN=lena-voice-hook-2026

# Debug mode (optional)
DEBUG=false
